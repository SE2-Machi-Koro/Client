# CI/CD Environment Variables Example
# Copy this file and rename to .env (for local development)
# For GitHub Actions, add these as Repository Secrets: Settings → Secrets and variables → Actions

# ============================================
# SonarCloud Configuration
# ============================================
# Required for: SonarCloud code quality analysis in CI/CD
# Generate at: https://sonarcloud.io/account/security
SONAR_TOKEN=your_sonarcloud_token_here

# ============================================
# Android Keystore Configuration (Release APK)
# ============================================
# Required for: Building and signing the Release APK in CI/CD
# Only needed if you want to generate signed Release APK on main branch push

# Path to the keystore file used by the Android build
# Local development: set this to the path of your .jks file
# GitHub Actions: decode the base64 secret to a file first, then set KEYSTORE_FILE to that decoded file path
KEYSTORE_FILE=path/to/your/keystore.jks

# GitHub Actions only: base64-encoded keystore content stored as a repository secret
# Example: base64 your_keystore.jks > keystore_base64.txt
# Then copy the contents of keystore_base64.txt into this variable/secret
KEYSTORE_BASE64=your_base64_encoded_keystore_here
# Password for the keystore file
KEYSTORE_PASSWORD=your_keystore_password_here

# Alias of the key inside the keystore
KEY_ALIAS=your_key_alias_here

# Password for the specific key
KEY_PASSWORD=your_key_password_here

# ============================================
# Notes
# ============================================
# - DO NOT commit .env file with real credentials to git
# - .env.example is safe to commit (it contains no sensitive data)
# - In GitHub Actions, these are passed as secrets automatically
# - For local development, create a .env file with your credentials
# - The CI pipeline will skip Release APK signing if KEYSTORE_* are not set

